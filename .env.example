# Public URLs
FRONTEND_PUBLIC_URL=http://localhost:8080
BACKEND_PUBLIC_URL=http://localhost:8080
VITE_SITE_URL=http://localhost:8080
VITE_API_BASE_URL=

# Backend app
DATABASE_URL=postgresql+asyncpg://edutest:edutest@db:5432/edutestai
ALEMBIC_DATABASE_URL=postgresql://edutest:edutest@db:5432/edutestai
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
SQL_ECHO=false

# External APIs
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=z-ai/glm-4.5-air:free
GOOGLE_SCRIPT_URL=
EXTERNAL_API_TIMEOUT_SECONDS=30
EXTERNAL_API_MAX_RETRIES=3
EXTERNAL_API_CONCURRENCY_LIMIT=3

# Postgres
POSTGRES_USER=edutest
POSTGRES_PASSWORD=edutest
POSTGRES_DB=edutestai
POSTGRES_PORT=5432

# MinIO / S3
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=edutestai-files
S3_REGION=
S3_USE_SSL=false
MAX_UPLOAD_SIZE_MB=10
ALLOWED_CONTENT_TYPES=application/pdf,image/jpeg,image/png,image/gif,text/plain,.pdf,.jpg,.jpeg,.png,.gif,.txt

# Reverse proxy
NGINX_PORT=8080
